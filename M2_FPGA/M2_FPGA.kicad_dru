(version 1)

(rule "edge con breakout"

  (condition "A.Type != 'Zone' && A.intersectsCourtyard('*:2242-key-E')")
  (constraint clearance (min 0.15mm) (opt 0.16mm) (max 0.2mm))
)

(rule "bevel edge clearance"
  (condition "A.Type == 'Pad' && A.memberOfFootprint('*:2242-key-E')")
  (constraint edge_clearance (min 0.35mm) (opt 0.35mm) (max 0.45mm))
)
